{
  "name": "mindscape",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun run --filter @repo/web dev",
    "dev:api": "bun run --filter @repo/api dev",
    "build:api":"bun run --filter @repo/api build",
    "build:web":"bun run --filter @repo/web build",
    "start:api":"bun run --filter @repo/api start",
    "start:debug:api":"bun run --filter @repo/api start:debug",
    "start:web":"bun run --filter @repo/web start",
    "db:generate": "bun run --filter @repo/db db:generate",
    "db:migrate": "bun run --filter @repo/db db:migrate",
    "db:push": "bun run --filter @repo/db db:push",
    "db:pull": "bun run --filter @repo/db db:pull",
    "db:up": "bun run --filter @repo/db db:up",
    "db:studio": "bun run --filter @repo/db db:studio"
  },
  "module": "index.ts",
  "type": "module",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
